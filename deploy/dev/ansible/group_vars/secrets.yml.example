# Copy to secrets.yml (which is gitignored) and fill in real values.
# Each entry is `<developer>:<key>` — the developer prefix binds the key
# to a tenant identity. Generate strong key values:
#     openssl rand -hex 32
observer_api_keys:
  - "alice@example.com:replace_me_with_a_strong_key"
  - "bob@example.com:optional_second_key"
