# Caddy automatically provisions and renews a Let's Encrypt certificate
# for {$DOMAIN} via the HTTP-01 challenge. Make sure the A record is
# pointing at this host and port 80 is reachable from the internet.

{$DOMAIN} {
  encode zstd gzip

  # Forward to the ingestor. Caddy adds X-Forwarded-* headers automatically.
  reverse_proxy observer-api:19900

  # Request body cap. Defaults to 48 MB so Caddy never 413s before the
  # ingestor (default 32 MiB) does. Override via CADDY_MAX_BODY in .env
  # if you bump OBSERVER_MAX_BODY_BYTES on the api side.
  request_body {
    max_size {$CADDY_MAX_BODY:48MB}
  }

  # Quiet down logs in dev — flip to DEBUG if something's off.
  log {
    output stdout
    format console
    level INFO
  }
}
