# Copy to .env on the deployment host. Real .env is gitignored — never
# commit it. Do not put AWS keys here; they come from the EC2 instance role.

# Hostname Caddy will request a cert for. Must already have an A record
# pointing at this host's public IP.
DOMAIN=api.dev.observer.apelogic.ai

# Comma-separated list of accepted Bearer keys for /api/ingest.
# Generate strong values, e.g.:
#   openssl rand -hex 32
OBSERVER_API_KEYS=replace_me_with_a_strong_key,optional_second_key

# S3 storage. Bucket comes from terraform output (`bucket_name`).
OBSERVER_S3_BUCKET=observer-dev-CHANGE-ME
OBSERVER_S3_REGION=us-west-2
