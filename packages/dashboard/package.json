{
  "name": "@observer/dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./runtime": "./server/runtime.ts"
  },
  "scripts": {
    "dev": "bun run dev:api & next dev",
    "dev:turbo": "bun run dev:api & next dev --turbopack",
    "dev:api": "bun --watch server/index.ts",
    "build": "next build && bun scripts/bundle-static.ts",
    "preview": "bun run build && bun server/index.ts",
    "start": "bun server/index.ts",
    "compile": "bun run build && bun build --compile server/compiled-entry.ts --outfile dist/observer-dashboard",
    "typecheck": "bun scripts/ensure-stubs.ts && bunx tsc --noEmit && bunx tsc --noEmit -p tsconfig.server.json",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "duckdb-async": "^1.4.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
