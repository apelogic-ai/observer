{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun"],
    "noEmit": true
  },
  "include": [
    "server/**/*.ts",
    "scripts/**/*.ts",
    "tests/server/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "out", ".next"]
}
